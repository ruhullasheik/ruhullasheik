#!/bin/sh
# Regenerate resume PDF and rebuild MkDocs site if source files changed

if git diff --cached --name-only | grep -q "pages/Ruhulla_Sheik_Resume.md"; then
    echo "Resume MD changed — regenerating PDF..."
    uv run python generate_resume.py
    git add pages/Ruhulla_Sheik_Resume.pdf
    echo "PDF updated and staged."
fi

if git diff --cached --name-only | grep -qE "pages/|mkdocs\.yml"; then
    echo "Docs changed — rebuilding MkDocs site..."
    uv run mkdocs build --quiet
    git add docs/
    echo "Site rebuilt and staged."
fi
